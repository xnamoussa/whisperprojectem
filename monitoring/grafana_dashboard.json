{
  "dashboard": {
    "uid": "ad2gqmd",
    "title": "MLOps Monitoring - Mobility Analytics",
    "tags": ["mlops", "monitoring", "prometheus"],
    "timezone": "browser",
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "API Traffic (Requests/sec)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(django_http_requests_total_by_method_total[1m])",
            "legendFormat": "{{method}}",
            "refId": "A"
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "fillOpacity": 15,
              "lineWidth": 2,
              "pointSize": 5,
              "gradientMode": "scheme"
            },
            "unit": "reqps"
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      {
        "id": 2,
        "title": "Response Latency (p50 / p90 / p99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.90, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
            "legendFormat": "p90",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(django_http_requests_latency_seconds_by_view_method_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "fillOpacity": 10,
              "lineWidth": 2,
              "gradientMode": "scheme"
            },
            "unit": "s"
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      {
        "id": 3,
        "title": "Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(django_http_responses_total_by_status_view_method{status=~\"5..\"}[5m])",
            "legendFormat": "{{status}} - {{view}}",
            "refId": "A"
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"fixedColor": "red", "mode": "fixed"},
            "custom": {
              "fillOpacity": 30,
              "lineWidth": 2,
              "gradientMode": "scheme"
            },
            "unit": "reqps"
          }
        },
        "options": {
          "legend": {"displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      {
        "id": 4,
        "title": "Model Accuracy vs Baseline (80%)",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "ml_model_accuracy",
            "legendFormat": "{{ministry}} - {{model_name}}",
            "refId": "A"
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "orange", "value": 0.7},
                {"color": "yellow", "value": 0.8},
                {"color": "green", "value": 0.9}
              ]
            },
            "min": 0,
            "max": 1,
            "unit": "percentunit"
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 5,
        "title": "Data Drift Score by Feature",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "topk(10, ml_data_drift_score)",
            "legendFormat": "{{ministry}} / {{feature}}",
            "refId": "A",
            "instant": true
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.1},
                {"color": "red", "value": 0.2}
              ]
            },
            "min": 0,
            "max": 1
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true
        }
      },
      {
        "id": 6,
        "title": "Pipeline Duration",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "ml_pipeline_duration_seconds_sum",
            "legendFormat": "{{pipeline_type}}",
            "refId": "A"
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 300}
              ]
            },
            "unit": "s"
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 7,
        "title": "Pipeline Errors (Total)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
        "targets": [
          {
            "expr": "ml_pipeline_errors_total",
            "legendFormat": "{{pipeline_type}} - {{ministry}}",
            "refId": "A"
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "orange", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background",
          "textMode": "value_and_name"
        }
      },
      {
        "id": 8,
        "title": "HTTP Responses by Status Code",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sum by (status) (django_http_responses_total_by_status_total)",
            "legendFormat": "HTTP {{status}}",
            "refId": "A",
            "instant": true
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"}
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "legend": {"displayMode": "table", "placement": "right"},
          "pieType": "donut"
        }
      },
      {
        "id": 9,
        "title": "Active Requests (Real-Time)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16},
        "targets": [
          {
            "expr": "django_http_requests_total_by_method_total",
            "legendFormat": "{{method}} requests",
            "refId": "A",
            "instant": false
          }
        ],
        "datasource": {"type": "prometheus", "uid": "bfkurgn4bn11cf"},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "fillOpacity": 20,
              "lineWidth": 2,
              "gradientMode": "scheme",
              "stacking": {"mode": "normal"}
            }
          }
        },
        "options": {
          "legend": {"displayMode": "list", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      }
    ]
  },
  "overwrite": true
}
